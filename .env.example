# Copy to .env.local for local dev. Add the same keys in Vercel → Environment Variables.

# Project Settings → General → Project URL
VITE_SUPABASE_URL=https://你的项目编号.supabase.co

# Settings → API Keys → Publishable key (sb_publishable_...)
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_你的key

# Legacy anon JWT key also works if your project still shows one:
# VITE_SUPABASE_ANON_KEY=eyJ...

# --- Server only (Vercel + local vercel dev). NEVER expose in frontend ---
# SUPABASE_SERVICE_ROLE_KEY=eyJ...
# SMS_DEV_MODE=true
# OTP_SECRET=random-long-string
